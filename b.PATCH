 	@echo ">>> Installing Emscripten SDK $(EMSDK_VER)..."
 	@if [ ! -d "$(EMSDK_DIR)" ]; then \
 		git clone https://github.com/emscripten-core/emsdk.git "$(EMSDK_DIR)"; \
