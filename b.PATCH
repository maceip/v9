+console.log('=== Release Gate Tests ===\n');
+
+let passed = 0;
+let failed = 0;
+
+function test(name, fn) {
+  try {
+    fn();
+    console.log(`  PASS: ${name}`);
+    passed++;
+  } catch (error) {
+    console.log(`  FAIL: ${name} — ${error.message}`);
+    failed++;
