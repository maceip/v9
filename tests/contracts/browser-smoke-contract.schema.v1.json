{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://edgejs.local/tests/contracts/browser-smoke-contract.schema.v1.json",
  "title": "Browser Smoke Contract v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "defaults",
    "scenarios",
    "conversation"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "defaults": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "baseUrl",
        "protocolTimeoutMs",
        "navigationTimeoutMs",
        "smokeRenderWaitMs",
        "interactiveRenderWaitMs"
      ],
      "properties": {
        "baseUrl": {
          "type": "string",
          "minLength": 1
        },
        "protocolTimeoutMs": {
          "type": "integer",
          "minimum": 1
        },
        "navigationTimeoutMs": {
          "type": "integer",
          "minimum": 1
        },
        "smokeRenderWaitMs": {
          "type": "integer",
          "minimum": 1
        },
        "interactiveRenderWaitMs": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "scenarios": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/scenario"
      }
    },
    "conversation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scenarioId",
        "requiredEnvKey",
        "prompt",
        "responseWaitMs"
      ],
      "properties": {
        "scenarioId": {
          "type": "string",
          "minLength": 1
        },
        "requiredEnvKey": {
          "type": "string",
          "minLength": 1
        },
        "prompt": {
          "type": "string",
          "minLength": 1
        },
        "responseWaitMs": {
          "type": "integer",
          "minimum": 1
        }
      }
    }
  },
  "$defs": {
    "scenario": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "displayName",
        "bundlePath",
        "cliMarkers",
        "allowlistedRejectionSubstrings",
        "knownSkips",
        "phaseBudgetsMs"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "displayName": {
          "type": "string",
          "minLength": 1
        },
        "bundlePath": {
          "type": "string",
          "pattern": "^/dist/.+\\.js$"
        },
        "cliMarkers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "allowlistedRejectionSubstrings": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "knownSkips": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/knownSkip"
          }
        },
        "sessionKeys": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/sessionKey"
          }
        },
        "phaseBudgetsMs": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "smokeLoad",
            "smokeRender",
            "interactiveLoad",
            "interactiveRender"
          ],
          "properties": {
            "smokeLoad": {
              "type": "integer",
              "minimum": 1
            },
            "smokeRender": {
              "type": "integer",
              "minimum": 1
            },
            "interactiveLoad": {
              "type": "integer",
              "minimum": 1
            },
            "interactiveRender": {
              "type": "integer",
              "minimum": 1
            }
          }
        }
      }
    },
    "knownSkip": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "scope",
        "matchSubstring",
        "issueUrl",
        "expiresOn"
      ],
      "properties": {
        "code": {
          "type": "string",
          "minLength": 1
        },
        "scope": {
          "enum": [
            "smoke",
            "interactivity",
            "all"
          ]
        },
        "matchSubstring": {
          "type": "string",
          "minLength": 1
        },
        "issueUrl": {
          "type": "string",
          "pattern": "^https?://"
        },
        "expiresOn": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        }
      }
    },
    "sessionKey": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "fromEnv": {
          "type": "string",
          "minLength": 1
        },
        "fallback": {
          "type": "string"
        }
      }
    }
  }
}
