# Build output (intermediate)
build/
edgejs-src/
.node-wasix32/

# dist/ is ignored EXCEPT the vendored wasm runtime.
# Core devs: `npm run build` produces these.
# Embedding devs: `npm run vendor:wasm` fetches pre-built artifacts.
dist/*
!dist/edgejs.js
!dist/edgejs.wasm

# Dependencies
node_modules/

# Vendored claude-js source (zip extract / local mirror)
claude-code-main/

# OS
.DS_Store
Thumbs.db

# Editors
*.swp
*.swo
*~
.vscode/
.idea/

# Emscripten cache
.emscripten_cache/
*.bc
*.o
*.a

# Logs
*.log

# Ephemeral / agent scratch
.tmp/

# v9 CLI build artifacts (generated by `v9 build` in user projects)
.v9-build/

# GitHub Pages generated runtime (see scripts/prepare-github-pages.mjs)
docs/web/
docs/napi-bridge/
docs/dist/

# Local secrets and one-off debug artifacts
.github/.env
run_stage1.mjs
stage1_response.txt
will_delete/
